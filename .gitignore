# Jekyll build output + caches
_site/
.jekyll-cache/
.jekyll-metadata
.sass-cache/

# Bundler
vendor/
.bundle/

# Node (generate-docs runner)
node_modules/

# Swagger UI shells — regenerated by scripts/generate-docs.js at build (not committed)
docs/api/swagger-ui.html
docs/zoneweaver-agent/api/swagger-ui.html

# Baked OpenAPI spec — specs are fetched live at runtime now, never bundled
docs/api/openapi.json

# Component changelogs — fetched from each repo at build by scripts/generate-docs.js
changelogs/

# OS / editor cruft
.DS_Store
Thumbs.db
